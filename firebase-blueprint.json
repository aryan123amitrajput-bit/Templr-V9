{
  "entities": {
    "Template": {
      "title": "Template",
      "description": "A template created by a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the template." },
        "preview_image": { "type": "string", "description": "The main preview image URL." },
        "banner_url": { "type": "string", "description": "The banner image URL." },
        "category": { "type": "string", "description": "The category of the template." },
        "price": { "type": "string", "description": "The price of the template." },
        "author_name": { "type": "string", "description": "The author's name." },
        "author_email": { "type": "string", "description": "The author's email." },
        "author_avatar": { "type": "string", "description": "The author's avatar URL." },
        "author_uid": { "type": "string", "description": "The author's Firebase UID." },
        "file_name": { "type": "string", "description": "The file name." },
        "file_type": { "type": "string", "description": "The file type." },
        "file_size": { "type": "number", "description": "The file size in bytes." },
        "status": { "type": "string", "description": "The status of the template.", "enum": ["approved", "pending_review", "rejected", "draft"] },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for the template." },
        "description": { "type": "string", "description": "The description of the template." },
        "video_url": { "type": "string", "description": "The video URL." },
        "gallery_images": { "type": "array", "items": { "type": "string" }, "description": "Gallery image URLs." },
        "template_url": { "type": "string", "description": "The template URL." },
        "file_url": { "type": "string", "description": "The file URL." },
        "views": { "type": "number", "description": "Number of views." },
        "likes": { "type": "number", "description": "Number of likes." },
        "sales": { "type": "number", "description": "Number of sales." },
        "earnings": { "type": "number", "description": "Total earnings." },
        "created_at": { "type": "number", "description": "Creation timestamp." }
      },
      "required": ["title", "author_email", "author_uid", "created_at"]
    },
    "User": {
      "title": "User",
      "description": "User profile and stats.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase UID." },
        "email": { "type": "string", "description": "User email." },
        "display_name": { "type": "string", "description": "Display name." },
        "avatar_url": { "type": "string", "description": "Avatar URL." },
        "banner_url": { "type": "string", "description": "Banner URL." },
        "is_pro": { "type": "boolean", "description": "Pro status." },
        "usage_count": { "type": "number", "description": "Usage count." },
        "role": { "type": "string", "description": "User role.", "enum": ["user", "admin"] },
        "created_at": { "type": "number", "description": "Creation timestamp." }
      },
      "required": ["uid", "email", "created_at"]
    }
  },
  "firestore": {
    "/templates/{templateId}": {
      "schema": { "$ref": "#/entities/Template" },
      "description": "Stores all templates."
    },
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    }
  }
}
